{#- Menu de navigation COMMUN — source unique. Préfigure header.php (WordPress). -#}
<a class="skip-link" href="#contenu">Aller au contenu</a>
<header class="site-header" data-header>
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label="{{ site.legal }} — accueil">
      <span class="brand__mark">{{ site.name }}</span>
      <span class="brand__sub">Sion · Valais</span>
    </a>

    <button class="nav-toggle" data-nav-toggle aria-expanded="false" aria-controls="nav-principal">
      <span class="nav-toggle__bar" aria-hidden="true"></span>
      <span class="sr-only">Ouvrir le menu</span>
    </button>

    <nav id="nav-principal" class="site-nav" data-nav aria-label="Navigation principale">
      <ul class="site-nav__list">
        {%- for item in site.nav %}
        <li>
          <a href="{{ item.url }}"
             class="site-nav__link{% if page.url == item.url %} is-active{% endif %}"
             {% if page.url == item.url %}aria-current="page"{% endif %}>
            {{ item.label }}
          </a>
        </li>
        {%- endfor %}
      </ul>
    </nav>
  </div>
</header>
