{#- Footer COMMUN — source unique. Préfigure footer.php (WordPress). -#}
<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <span class="brand__mark">{{ site.name }}</span>
      <p>{{ site.tagline }}</p>
    </div>

    <div class="site-footer__col">
      <h2 class="site-footer__title">Nos logements</h2>
      <ul>
        <li><a href="{{ '/lot-1/' | url }}">Location courte durée</a></li>
        <li><a href="{{ '/lot-2/' | url }}">Location longue durée — colocation</a></li>
      </ul>
    </div>

    <div class="site-footer__col">
      <h2 class="site-footer__title">Contact</h2>
      <address>
        {{ site.legal }}<br>
        {{ site.address }}
      </address>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container">
      <p>© {% year %} {{ site.legal }} — Tous droits réservés.</p>
      <p class="site-footer__credit">Brouillon de présentation · Caractère Communication</p>
    </div>
  </div>
</footer>
